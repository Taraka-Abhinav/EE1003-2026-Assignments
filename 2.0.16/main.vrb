\frametitle{CVXPY Implementation}
\begin{lstlisting}

for i in range(n):
    for j in range(n):
        if i != j:
            constraints += [
                C[i] + p[j] <= C[j] + M*(1 - X[i,j])
            ]

prob = cp.Problem(cp.Minimize(Tmax), constraints)
prob.solve(solver=cp.ECOS_BB)
\end{lstlisting}
