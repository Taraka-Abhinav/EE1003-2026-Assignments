\frametitle{Overlay Plot -- C Code}
\begin{lstlisting}
#include <stdio.h>
#include <math.h>

int main() {
    double t, V=5, tau=0.04;

    for(int i=0;i<=200;i++){
        t = i/1000.0;
        double Vc = V*(1-exp(-t/tau));
        double ic = (V/10000.0)*exp(-t/tau)*1000;

        printf("%lf %lf %lf\n", t*1000, Vc, ic);
    }
    return 0;
}
\end{lstlisting}
